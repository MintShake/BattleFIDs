{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/tier?secret=26b07f1012eaa3008b1a257c7ff270fd",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/score?secret=26b07f1012eaa3008b1a257c7ff270fd",
      "schedule": "0 0 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/.well-known/farcaster.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/(og|splash|icon).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
